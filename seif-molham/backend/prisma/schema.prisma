generator client { provider = "prisma-client-js" }

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("EMPLOYEE")
  createdAt DateTime @default(now())
}

model Employee {
  id         Int      @id @default(autoincrement())
  name       String
  position   String?
  department String?
  location   String?
}
